# AQICN API - Get your free API key at https://aqicn.org/api/
AQICN_API_KEY=your_aqicn_key_here

# OpenWeatherMap API - Get key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# Hugging Face Inference API (For AI Chatbot)
# Get your free token at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here

# Geolocation API (optional, for auto-detection)
NEXT_PUBLIC_ENABLE_GEOLOCATION=true
